local GRADE_ORDER = {D=1,C=2,B=3,A=4,S=5}
local GRADE_NAMES = {"D","C","B","A","S"}

local function numToGrade(n)
    return GRADE_NAMES[math.max(1, math.min(5, math.round(tonumber(n) or 1)))]
end

local function gradeGE(g, minG)
    return (GRADE_ORDER[g] or 0) >= (GRADE_ORDER[minG] or 0)
end

local function lerpN(a, b, t) return a + (b - a) * t end

local function lerpColor(a, b, t)
    return Color3.new(
        a.R + (b.R-a.R)*t,
        a.G + (b.G-a.G)*t,
        a.B + (b.B-a.B)*t)
end

local function hsvCycleColor(t)
    return Color3.fromHSV((t * 0.125) % 1, 0.88, 0.55)
end

local function parseStand(raw)
    raw = tostring(raw or "")
    local info = {name="Unknown",skin=nil,trait="Unknown",strength=1,speed=1,specialty=1}
    local ok, t = pcall(HttpService.JSONDecode, HttpService, raw)
    if not ok then
        local s = raw:find("{")
        if s then
            local depth, e = 0, nil
            for i = s, #raw do
                local ch = raw:sub(i,i)
                if ch=="{" then
                    depth += 1
                elseif ch=="}" then
                    depth -= 1
                    if depth==0 then
                        e=i
                        break
                    end
                end
            end
            if e then
                ok,t = pcall(HttpService.JSONDecode, HttpService, raw:sub(s,e))
            end
        end
    end
    if ok and type(t)=="table" then
        if type(t.Name)=="string"     and t.Name~=""  then info.name  = t.Name  end
        if type(t.Skin)=="string"     and t.Skin~=""  then info.skin  = t.Skin  end
        if type(t.Trait)=="string"    and t.Trait~="" then info.trait = t.Trait end
        info.strength  = math.max(1,math.min(5, tonumber(t.Strength)  or 1))
        info.speed     = math.max(1,math.min(5, tonumber(t.Speed)     or 1))
        info.specialty = math.max(1,math.min(5, tonumber(t.Specialty) or 1))
    end
    return info
end

-- ═══════════════════════════════════════════════════════════
--  STOP CONDITION CHECKER
-- ═══════════════════════════════════════════════════════════
local function checkStop(info)
    local g = {
        str = numToGrade(info.strength),
        spd = numToGrade(info.speed),
        spc = numToGrade(info.specialty),
    }
    local allS       = g.str=="S" and g.spd=="S" and g.spc=="S"
    local traitLower = info.trait:lower()

    -- Global jackpot: all S + selected skin + mythical trait
    local MYTHICAL_TRAITS = {"transcendent","feral","demonic","elegant"}
    local isMythical = false
    for _, mt in ipairs(MYTHICAL_TRAITS) do
        if traitLower == mt then isMythical=true; break end
    end
    if Settings.globalStop and allS and isMythical and info.skin then
        -- skin must be one we have selected in any condition
        local skinSelected = false
        for _, cond in ipairs(Conditions) do
            for _, s in ipairs(cond.skins or {}) do
                if info.skin:lower():find(s:lower(), 1, true) then
                    skinSelected=true; break
                end
            end
            if skinSelected then break end
        end
        if skinSelected then return "GLOBAL_JACKPOT" end
    end

    for _, cond in ipairs(Conditions) do
        -- Step 2: skin match — independent of stand/stats
        if info.skin and #(cond.skins or {}) > 0 then
            for _, s in ipairs(cond.skins) do
                if info.skin:lower():find(s:lower(), 1, true) then
                    -- skin + trait + stats met = jackpot
                    local skinStatsMatch = gradeGE(g.str, cond.minStr)
                        and gradeGE(g.spd, cond.minSpd)
                        and gradeGE(g.spc, cond.minSpc)
                    local skinTraitMatch = #(cond.traits or {}) > 0 and (function()
                        for _, tr in ipairs(cond.traits) do
                            if traitLower == tr:lower() then return true end
                        end
                        return false
                    end)()
                    if skinTraitMatch and skinStatsMatch then
                        return "CONDITION_JACKPOT"
                    end
                    return "CONDITION_SKIN"
                end
            end
        end

        local standMatch = false
        for _, sn in ipairs(cond.stands or {}) do
            if info.name == sn then standMatch=true; break end
        end

        if standMatch then
            local statsMatch = gradeGE(g.str, cond.minStr)
                and gradeGE(g.spd, cond.minSpd)
                and gradeGE(g.spc, cond.minSpc)

            -- Step 3: stand + trait match, stats irrelevant
            if #(cond.traits or {}) > 0 then
                for _, tr in ipairs(cond.traits) do
                    if traitLower == tr:lower() then
                        -- stand + stats + trait = jackpot
                        return statsMatch and "CONDITION_JACKPOT" or "CONDITION_TRAIT"
                    end
                end
            end

            -- Step 1: stand + stats meet minimum (no trait requirement)
            if statsMatch then
                return "CONDITION_MET"
            end
        end
    end
    return nil
end

-- ═══════════════════════════════════════════════════════════
--  WEBHOOK
-- ═══════════════════════════════════════════════════════════
local function sendWebhook(info, reason)
    if Settings.webhookURL=="" then return end
    local send = false
    if reason=="GLOBAL_JACKPOT" or reason=="CONDITION_JACKPOT" then
        send = Settings.webhookOnJackpot
    elseif reason:find("CONDITION") then
        send = Settings.webhookOnCondition
    end
    if not send then return end

    local g = {numToGrade(info.strength), numToGrade(info.speed), numToGrade(info.specialty)}
    local body = HttpService:JSONEncode({
        username = "StandRoll HUD",
        embeds = {{
            title = reason:gsub("_"," "),
            description = string.format("**%s**%s\nTrait: %s\nSTR `%s`  SPD `%s`  SPC `%s`",
                info.name,
                info.skin and ("  ·  skin: **"..info.skin.."**") or "",
                info.trait, g[1], g[2], g[3]),
            color = 0xF0C030,
        }},
    })

    local remote = ReplicatedStorage:FindFirstChild("WebhookProxy")
    if remote then
        remote:FireServer(Settings.webhookURL, body)
    end
end

