            autoBtn.BackgroundColor3=C.btnBg
            autoBtnStroke.Color=C.btnBorder
            autoBtn.TextColor3=C.textDim
            autoBtn.Text="AUTO OFF"
        end
        local sc,st=C.textFaint,"IDLE"
        if     stopReason=="GLOBAL_JACKPOT" or stopReason=="CONDITION_JACKPOT" then sc=C.gold;   st="✦  jackpot!"
        elseif stopReason=="CONDITION_TRAIT"   then sc=C.purple; st="★  trait match"
