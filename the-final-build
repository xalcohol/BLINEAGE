--  HUD UPDATE
-- ═══════════════════════════════════════════════════════════
local lastSig    = ""
local lastGrades = {str="D",spd="D",spc="D"}
local rainbowOn  = false

local function updateHUD()
    if not alive then return end
    local info=parseStand(StandValue.Value)

    nameLabel.Text=info.name

    if info.skin and info.skin~="" then
        local bounds=TextService:GetTextSize(info.skin,10,Enum.Font.GothamBold,Vector2.new(300,20))
        skinPill.Size=UDim2.new(0,bounds.X+16,0,20)
        skinPillLabel.Text=info.skin
        skinPill.Visible=true
    else
        skinPill.Visible=false
    end

    traitValLabel.Text=(info.trait~="Unknown") and info.trait or "—"
    traitValLabel.TextColor3=(info.trait:lower()=="transcendent") and C.purple or C.textDim

    local g={str=numToGrade(info.strength),spd=numToGrade(info.speed),spc=numToGrade(info.specialty)}
    lastGrades=g
    rainbowOn=g.str=="S" and g.spd=="S" and g.spc=="S"

    for i,key in ipairs({"str","spd","spc"}) do
        local grade=g[key]
        local obj=statObjects[i]
        obj.gradeLbl.Text=grade
        obj.gradeLbl.TextColor3=gc(grade)
        obj.bar.BackgroundColor3=bc(grade)
        obj.bar.Size=UDim2.new(GRADE_ORDER[grade]/5,0,1,0)
    end

    local sig=string.format("%s|%s|%s|%d|%d|%d",
        info.name,tostring(info.skin),info.trait,info.strength,info.speed,info.specialty)
    if sig==lastSig then return end
    lastSig=sig

    if autoroll then
        local reason=checkStop(info)
        if reason then
            stopAutoroll(reason)
            sendWebhook(info,reason)
            if reason:find("JACKPOT") then
                triggerFlash()
            end
        end
    else
        -- stand changed manually — re-evaluate and update status display
        local reason = checkStop(info)
        stopReason = reason or "IDLE"
    end
end

