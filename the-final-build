local function newFrame(parent, p)
    local f = Instance.new("Frame")
    f.BackgroundColor3       = p.BackgroundColor3       or Color3.fromRGB(0,0,0)
    f.BackgroundTransparency = p.BackgroundTransparency or 0
    f.BorderSizePixel        = 0
    f.Size                   = p.Size     or UDim2.new(0,10,0,10)
    f.Position               = p.Position or UDim2.new(0,0,0,0)
    f.AnchorPoint            = p.AnchorPoint or Vector2.new(0,0)
    f.ZIndex                 = p.ZIndex   or 1
    f.Visible                = p.Visible  ~= nil and p.Visible or true
    if p.Name then f.Name=p.Name end
    f.Parent=parent
    return f
end

local function newLabel(parent, p)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = p.BackgroundTransparency ~= nil and p.BackgroundTransparency or 1
    l.BorderSizePixel        = 0
    l.Size           = p.Size           or UDim2.new(0,100,0,20)
    l.Position       = p.Position       or UDim2.new(0,0,0,0)
    l.AnchorPoint    = p.AnchorPoint    or Vector2.new(0,0)
    l.ZIndex         = p.ZIndex         or 1
    l.Font           = p.Font           or Enum.Font.Gotham
    l.TextSize       = p.TextSize       or 14
    l.TextColor3     = p.TextColor3     or Color3.fromRGB(255,255,255)
    l.TextXAlignment = p.TextXAlignment or Enum.TextXAlignment.Left
    l.TextYAlignment = p.TextYAlignment or Enum.TextYAlignment.Center
    l.Text           = p.Text           or ""
    l.TextWrapped    = p.TextWrapped or false
    if p.Name then l.Name=p.Name end
    l.Parent=parent
    return l
end

local function newButton(parent, p)
    local b = Instance.new("TextButton")
    b.BackgroundColor3       = p.BackgroundColor3       or C.btnBg
    b.BackgroundTransparency = p.BackgroundTransparency or 0
    b.BorderSizePixel        = 0
    b.Size           = p.Size           or UDim2.new(0,100,0,30)
    b.Position       = p.Position       or UDim2.new(0,0,0,0)
    b.AnchorPoint    = p.AnchorPoint    or Vector2.new(0,0)
    b.ZIndex         = p.ZIndex         or 1
    b.Font           = p.Font           or Enum.Font.GothamBold
