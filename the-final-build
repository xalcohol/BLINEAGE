local function openSubWin(win)
    task.defer(function()
        local hp = hudHolder.AbsolutePosition
        local hs = hudHolder.AbsoluteSize
        local vp = workspace.CurrentCamera.ViewportSize
        if hp.X == 0 and hp.Y == 0 then
            hp = Vector2.new(20, vp.Y / 2 - 100)
            hs = Vector2.new(CARD_W, 200)
        end
        local winW = win.AbsoluteSize.X > 0 and win.AbsoluteSize.X or 300
        local hudCentreX = hp.X + hs.X * 0.5
        local xPos
        if hudCentreX < vp.X * 0.5 then
            xPos = hp.X + hs.X + 10
        else
            xPos = hp.X - winW - 10
        end
        xPos = math.max(4, math.min(xPos, vp.X - winW - 4))
        win.Position = UDim2.new(0, xPos, 0, math.max(4, hp.Y))
        win.Visible  = true
    end)
end

