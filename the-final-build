        elseif stopReason=="CONDITION_SKIN"    then sc=C.red;    st="◇  rare skin"
        elseif stopReason=="MANUAL"            then sc=Color3.fromRGB(50,50,70); st="stopped"
        end
        statusLabel.TextColor3=sc
        statusLabel.Text=st
    end
end))
