local CFG_FILE = "StandRollHUD_configs.json"
local function fileRead()
    local ok, data = pcall(readfile, CFG_FILE)
    return (ok and type(data)=="string") and data or ""
end
local function fileWrite(data)
    pcall(writefile, CFG_FILE, data)
end

local function serializeConfig()
    local conds = {}
    for _, c in ipairs(Conditions) do
        table.insert(conds, {
            stands = c.stands,
            minStr = c.minStr, minSpd = c.minSpd, minSpc = c.minSpc,
            skins  = c.skins,  traits = c.traits,
        })
    end
    return {
        conditions    = conds,
        globalStop    = Settings.globalStop,
        autorollDelay = Settings.autorollDelay,
        webhookURL    = Settings.webhookURL,
    }
end

local function applyConfig(cfg)
    if type(cfg) ~= "table" then return end

    while #Conditions > 0 do
        table.remove(Conditions)
    end

    for _, c in ipairs(cfg.conditions or {}) do
        table.insert(Conditions, {
            stands = c.stands or {},
            minStr = c.minStr or "A",
            minSpd = c.minSpd or "A",
            minSpc = c.minSpc or "A",
            skins  = c.skins  or {},
            traits = c.traits or {},
        })
    end

    if cfg.globalStop ~= nil then
        Settings.globalStop = cfg.globalStop
    end
    if cfg.autorollDelay ~= nil then
        Settings.autorollDelay = cfg.autorollDelay
        delayVal.Text = string.format("%.2f", Settings.autorollDelay)
    end
    if cfg.webhookURL ~= nil then
        Settings.webhookURL = cfg.webhookURL
        urlBox.Text = cfg.webhookURL
    end

    condListOpen = true
    condListContainer.Visible = true
    condChevBtn.Text = "▼"

    if renderConditions then
        renderConditions()
    end
end

local function persistConfigs()
    local t = { configs = {}, autoload = autoloadName }
    for _, cfg in ipairs(savedConfigs) do
        table.insert(t.configs, cfg)
    end
    local ok, encoded = pcall(HttpService.JSONEncode, HttpService, t)
    if ok then fileWrite(encoded) end
end

