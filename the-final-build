local COND_COLORS = {
    Color3.fromRGB(170,51,51),  Color3.fromRGB(170,128,32),
    Color3.fromRGB(85,153,238), Color3.fromRGB(68,187,102),
    Color3.fromRGB(153,68,204), Color3.fromRGB(204,102,34),
}
local function condColor(stands)
    if not stands or #stands==0 then return COND_COLORS[1] end
    local h=0
    for ch in tostring(stands[1]):gmatch(".") do
        h=(h*31+ch:byte())%#COND_COLORS
    end
    return COND_COLORS[h+1]
end

