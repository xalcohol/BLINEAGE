--  AUTOROLL ENGINE
-- ═══════════════════════════════════════════════════════════
local alive          = true
local autoroll       = false
local rollGen        = 0
local stopReason     = "IDLE"
local connections    = {}

local function stopAutoroll(reason)
    autoroll   = false
    stopReason = reason or "MANUAL"
end

local function startAutoroll()
    if autoroll then return end
    autoroll = true
    stopReason = "IDLE"
    rollGen += 1
    local gen = rollGen
    task.spawn(function()
        while alive and autoroll and rollGen==gen do
            useItem:FireServer("Stand Arrow")
            task.wait(Settings.autorollDelay)
        end
    end)
end

local function toggleAutoroll()
    if autoroll then stopAutoroll("MANUAL") else startAutoroll() end
end

local function killScript()
    if not alive then return end
    alive=false; autoroll=false; rollGen+=1
    for _,c in ipairs(connections) do pcall(function() c:Disconnect() end) end
    local hud = PlayerGui:FindFirstChild("StandRollHUD")
    if hud then hud:Destroy() end
    script:Destroy()
end

