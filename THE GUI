--==========================================================
--  RUNTIME CONSTANTS  (populated from game folders)
--==========================================================
local STAND_NAMES = {}   -- all stand names in the game
local SKIN_LIST   = {}   -- { {name=string, stand=string}, ... }

do
    -- Collect stand names (every direct child of "stands" that isn't "Skins")
    for _, child in ipairs(standsFolder:GetChildren()) do
        if child.Name ~= "Skins" then
            table.insert(STAND_NAMES, child.Name)
        end
    end
    table.sort(STAND_NAMES)

    -- Collect skins — each skin model is a child of the Skins folder.
    -- Skin models are named "<SkinName>" and have a string attribute or
    -- a child called "Stand" indicating which stand they belong to.
    -- If that attribute is absent we leave stand = "Unknown".
    if skinsFolder then
        for _, skinModel in ipairs(skinsFolder:GetChildren()) do
            local standAttr = skinModel:GetAttribute("Stand")
                           or (skinModel:FindFirstChild("Stand") and skinModel.Stand.Value)
                           or "Unknown"
            table.insert(SKIN_LIST, { name = skinModel.Name, stand = standAttr })
        end
        table.sort(SKIN_LIST, function(a, b) return a.name < b.name end)
    end
end

