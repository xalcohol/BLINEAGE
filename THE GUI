--==========================================================
--  GLOW SYSTEM  (RenderStepped)
--  All windows share the same border color at the same tick.
--  Triple-S → slow rainbow cycle on all borders simultaneously.
--  Otherwise → average grade color, smoothly lerped.
--==========================================================
local glowR, glowG, glowB = 30, 30, 42
local targetR, targetG, targetB = 30, 30, 42

local GRADE_GLOW = {
    S = {200,160,40},
    A = {51,102,170},
    B = {42,122,68},
    C = {54,54,80},
    D = {30,30,42},
}

local function lerpN(a,b,t) return a+(b-a)*t end

local allStrokes = {cardStroke, stripStroke, settingsStroke, webhookStroke}

table.insert(connections, RunService.RenderStepped:Connect(function()
    if not alive then return end
    local t = tick()

    local allS = rainbowTargets.str and rainbowTargets.spd and rainbowTargets.spc

    -- Compute target glow color
    if allS then
        -- Rainbow: drive all strokes from same hue tick
        local hue = (t * 0.125) % 1
        local c = Color3.fromHSV(hue, 0.88, 0.95)
        local glow = Color3.fromHSV(hue, 0.88, 0.6)
        for _, s in ipairs(allStrokes) do
            s.Color = c
        end
        -- Grade letters rainbow
        for i, key in ipairs({"str","spd","spc"}) do
            statObjects[i].gradeLbl.TextColor3 = Color3.fromHSV(hue, 0.88, 1)
        end
        -- Skin pill
        if rainbowTargets.skin and skinPill.Visible then
            skinPillStroke.Color = Color3.fromHSV(hue, 0.88, 0.95)
            skinPill.BackgroundColor3 = Color3.fromHSV(hue, 0.88, 0.25)
        end
    else
        -- Average grade color
        local rr,gg,bb = 0,0,0
        for _, key in ipairs({"str","spd","spc"}) do
            local gc = GRADE_GLOW[lastGrades[key]] or GRADE_GLOW.D
            rr += gc[1]/3; gg += gc[2]/3; bb += gc[3]/3
        end
        targetR,targetG,targetB = rr,gg,bb
        glowR = lerpN(glowR, targetR, 0.055)
        glowG = lerpN(glowG, targetG, 0.055)
        glowB = lerpN(glowB, targetB, 0.055)
        local c = Color3.fromRGB(math.round(glowR),math.round(glowG),math.round(glowB))
        for _, s in ipairs(allStrokes) do s.Color = c end
        -- Restore grade letter colors (non-rainbow)
        for i, key in ipairs({"str","spd","spc"}) do
            statObjects[i].gradeLbl.TextColor3 = gradeColor(lastGrades[key])
        end
        -- Skin pill normal
        if skinPill.Visible then
            skinPillStroke.Color = Color3.fromRGB(200,134,10)
            skinPill.BackgroundColor3 = Color3.fromRGB(42,28,4)
        end
    end

    -- Special stand name pulse
    -- (isSpecial driven by condition check — TODO hook in)
    -- nameLabel.TextColor3 = ...

    -- Auto button pulse
    if autoroll then
        local p = (math.sin(t*4)+1)*0.5
        autoBtn.BackgroundColor3 = lerpColor(Color3.fromRGB(34,12,12), Color3.fromRGB(56,18,18), p)
        autoBtnStroke.Color      = lerpColor(Color3.fromRGB(102,20,20), Color3.fromRGB(200,44,44), p)
        autoBtn.TextColor3       = Color3.fromRGB(200,68,68)
        autoBtn.Text             = "AUTO  ON"
        statusLabel.Text         = "rolling..."
        statusLabel.TextColor3   = Color3.fromRGB(170,40,40)
    else
        autoBtn.BackgroundColor3 = C.btnBg
        autoBtnStroke.Color      = C.btnBorder
        autoBtn.TextColor3       = C.textDim
        autoBtn.Text             = "AUTO  OFF"

        local sc, st = C.textFaint, "IDLE"
        if stopReason == "GLOBAL_JACKPOT" or stopReason == "CONDITION_JACKPOT" then
            sc=C.gold;    st="\u2746  jackpot!"
        elseif stopReason == "CONDITION_TRAIT" then
            sc=C.purple;  st="\u2605  trait match"
        elseif stopReason == "CONDITION_MET" then
            sc=C.gradeA;  st="\u25c8  condition met"
        elseif stopReason == "CONDITION_SKIN" then
            sc=C.red;     st="\u25c8  rare skin"
        elseif stopReason == "MANUAL" then
            sc=Color3.fromRGB(50,50,70); st="stopped"
        end
        statusLabel.TextColor3 = sc
        statusLabel.Text       = st
    end
end))
