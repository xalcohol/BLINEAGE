--  AUTOROLL ENGINE
-- ═══════════════════════════════════════════════════════════
local function gradeValue(g)
    return ({D=1,C=2,B=3,A=4,S=5})[g] or 0
end

local function conditionMet(cond, stand, str, spd, spc, trait, skin)
    if #cond.stands>0 and not table.find(cond.stands,stand) then return false end
    if gradeValue(str)<gradeValue(cond.minStr) then return false end
    if gradeValue(spd)<gradeValue(cond.minSpd) then return false end
    if gradeValue(spc)<gradeValue(cond.minSpc) then return false end
    if #cond.traits>0 and not table.find(cond.traits,trait) then return false end
    if #cond.skins>0 and not table.find(cond.skins,skin) then return false end
    return true
end

local function checkConditions(stand, str, spd, spc, trait, skin)
    for _, cond in ipairs(Conditions) do
        if conditionMet(cond,stand,str,spd,spc,trait,skin) then return true end
    end
    return false
end

