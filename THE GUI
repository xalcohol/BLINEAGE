        D=C.gradeD, C=Color3.fromRGB(68,204,102), B=Color3.fromRGB(68,204,102),
        A=Color3.fromRGB(68,170,238), S=Color3.fromRGB(238,170,34),
    })[g] or C.gradeD
end

local function updateHUD()
    local stand = StandValue and StandValue.Value or "—"
    local trait = TraitValue and TraitValue.Value or "—"
    local str   = StrValue   and StrValue.Value   or "D"
    local spd   = SpdValue   and SpdValue.Value   or "D"
    local spc   = SpcValue   and SpcValue.Value   or "D"
    local skin  = SkinValue  and SkinValue.Value  or ""

    nameLabel.Text     = stand
    traitValLabel.Text = trait
    if skin ~= "" then
        skinPill.Visible=true; skinPillLabel.Text=skin
    else
        skinPill.Visible=false
    end

    local grades = {str, spd, spc}
    local function gradeToFraction(g) return ({D=0.1,C=0.35,B=0.6,A=0.8,S=1.0})[g] or 0 end
    for i, so in ipairs(statObjects) do
        local g = grades[i]
        so.gradeLbl.Text       = g
        so.gradeLbl.TextColor3 = getGradeColor(g)
        so.bar.Size            = UDim2.new(gradeToFraction(g),0,1,0)
        so.bar.BackgroundColor3 = getGradeColor(g)
    end

    -- check stop conditions
    if autoroll then
        if checkConditions(stand,str,spd,spc,trait,skin) then
            stopAutoroll("stopped")
            flashScreen(Color3.fromRGB(68,255,136))
        end
    end
end

