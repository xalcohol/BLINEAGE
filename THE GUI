local function openWin(win, refFrame)
    local rPos = refFrame.AbsolutePosition
    local rSz  = refFrame.AbsoluteSize
    win.Position = UDim2.new(0, rPos.X + rSz.X + 10, 0, rPos.Y)
    win.Visible  = true
end

local function toggleWin(win, btn, refFrame)
    if win.Visible then
        win.Visible = false
        btn.BackgroundTransparency = 1
        btn.TextColor3 = Color3.fromRGB(56,56,80)
    else
        openWin(win, refFrame)
        btn.BackgroundTransparency = 0.93
        btn.TextColor3 = C.white
    end
end

