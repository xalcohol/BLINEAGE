local t0=tick()
table.insert(connections, RunService.RenderStepped:Connect(function()
    local t=tick()
    local p=math.abs(math.sin((t-t0)*2))

    -- pulse auto button border when active
    if autoroll then
        local col=lerpColor(Color3.fromRGB(34,12,12),Color3.fromRGB(56,18,18),p)
        autoBtn.BackgroundColor3=col
        autoBtnStroke.Color=lerpColor(Color3.fromRGB(102,20,20),Color3.fromRGB(200,44,44),p)
        autoBtn.TextColor3=Color3.fromRGB(200,68,68)
        autoBtn.Text="AUTO ON"
    else
        autoBtn.BackgroundColor3=C.btnBg
        autoBtnStroke.Color=C.btnBorder
        autoBtn.TextColor3=C.textDim
        autoBtn.Text="AUTO OFF"
    end

    -- pulse card stroke when rolling
    if autoroll then
        cardStroke.Color=lerpColor(Color3.fromRGB(80,20,20),Color3.fromRGB(200,44,44),p)
        cardStroke.Thickness=1.5+(2.5-1.5)*p
    else
        cardStroke.Color=C.border
        cardStroke.Thickness=1.5
    end
end))

-- Heartbeat: sync settings, update HUD
table.insert(connections, RunService.Heartbeat:Connect(function()
    Settings.globalStop         = getGlobalStop()
    Settings.autorollDelay      = tonumber(delayVal.Text) or Settings.autorollDelay
    updateHUD()
end))

