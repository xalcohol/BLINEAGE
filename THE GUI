--==========================================================
--  HUD UPDATE  (called on StandValue.Changed)
--==========================================================
local lastSig   = ""
local lastGrades= {str="D",spd="D",spc="D"}

local rainbowTargets = {str=false,spd=false,spc=false,skin=false}

local function updateHUD()
    if not alive then return end
    local info = parseStand(StandValue.Value)

    nameLabel.Text = info.name

    -- Skin pill
    if info.skin and info.skin ~= "" then
        local tw = TextService:GetTextSize(info.skin, 10, Enum.Font.GothamBold, Vector2.new(300,20)).X
        skinPill.Size    = UDim2.new(0, tw+16, 0, 20)
        skinPillLabel.Text = info.skin
        skinPill.Visible = true
        rainbowTargets.skin = true
    else
        skinPill.Visible = false
        rainbowTargets.skin = false
    end

    -- Trait
    traitValLabel.Text      = info.trait ~= "Unknown" and info.trait or "—"
    traitValLabel.TextColor3= info.trait:lower()=="transcendent" and C.purple or C.textDim

    -- Stats
    local grades = {
        str = numToGrade(info.strength),
        spd = numToGrade(info.speed),
        spc = numToGrade(info.specialty),
    }
    lastGrades = grades
    local allS = grades.str=="S" and grades.spd=="S" and grades.spc=="S"

    for i, key in ipairs({"str","spd","spc"}) do
        local g   = grades[key]
        local obj = statObjects[i]
        rainbowTargets[key] = (g=="S")
        obj.gradeLbl.Text       = g
        obj.gradeLbl.TextColor3 = gradeColor(g)
        obj.bar.BackgroundColor3= barColor(g)
        obj.bar.Size = UDim2.new(GRADE_ORDER[g]/5, 0, 1, 0)
    end

    -- Stand name pulse for specials (re-evaluated each update)
    -- (driven by RenderStepped below)

    -- Signature check — only act on new rolls
    local sig = string.format("%s|%s|%s|%d|%d|%d",
        info.name, tostring(info.skin), info.trait,
        info.strength, info.speed, info.specialty)

    if sig ~= lastSig then
        lastSig = sig

        -- Flash on special stands that have skins
        local isSpecial = false  -- fill in from SPECIAL_STANDS if desired
        if isSpecial and info.skin then triggerFlash() end

        -- Check stop conditions
        if autoroll then
            local reason = checkStopConditions(info)
            if reason then
                stopAutoroll(reason)
                sendWebhook(info, reason)
            end
        end
    end
end

table.insert(connections, StandValue.Changed:Connect(updateHUD))
updateHUD()

