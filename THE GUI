--==========================================================
--  HELPERS
--==========================================================
local GRADE_ORDER = {D=1,C=2,B=3,A=4,S=5}

local function numToGrade(n)
    return ({"D","C","B","A","S"})[math.max(1,math.min(5, tonumber(n) or 1))]
end

local function gradeGE(g, minG)
    return (GRADE_ORDER[g] or 0) >= (GRADE_ORDER[minG] or 0)
end

local function parseStand(raw)
    raw = tostring(raw or "")
    local info = {name="Unknown",skin=nil,trait="Unknown",strength=1,speed=1,specialty=1}
    local ok, t = pcall(HttpService.JSONDecode, HttpService, raw)
    if not ok then
        local s,e = raw:find("{"), nil
        if s then
            local depth=0
            for i=s,#raw do
                local c=raw:sub(i,i)
                if c=="{" then depth+=1 elseif c=="}" then
                    depth-=1
                    if depth==0 then e=i break end
                end
            end
            if e then ok,t = pcall(HttpService.JSONDecode,HttpService,raw:sub(s,e)) end
        end
    end
    if ok and type(t)=="table" then
        if type(t.Name)=="string"  and t.Name~=""  then info.name     = t.Name  end
        if type(t.Skin)=="string"  and t.Skin~=""  then info.skin     = t.Skin  end
        if type(t.Trait)=="string" and t.Trait~="" then info.trait    = t.Trait end
        info.strength  = math.max(1,math.min(5,tonumber(t.Strength)  or 1))
        info.speed     = math.max(1,math.min(5,tonumber(t.Speed)     or 1))
        info.specialty = math.max(1,math.min(5,tonumber(t.Specialty) or 1))
    end
    return info
end

local function lerpColor(a, b, t)
    return Color3.new(a.R+(b.R-a.R)*t, a.G+(b.G-a.G)*t, a.B+(b.B-a.B)*t)
end

local function hsvCycle(t, s, v)
    return Color3.fromHSV((t*0.125)%1, s, v)   -- 8-second full cycle
end

--==========================================================
--  STOP CONDITION CHECKER
--  Returns: reason string or nil
--==========================================================
local function checkStopConditions(info)
    local grades = {
        str = numToGrade(info.strength),
        spd = numToGrade(info.speed),
        spc = numToGrade(info.specialty),
    }
    local allS = grades.str=="S" and grades.spd=="S" and grades.spc=="S"
    local traitLower = info.trait:lower()

    -- Global stop: Transcendent + All S (no condition required)
    if Settings.globalStop and allS and traitLower == "transcendent" then
        return "GLOBAL_JACKPOT"
    end

    -- Per-condition checks
    for _, cond in ipairs(Conditions) do
        local standMatch  = info.name == cond.stand
        local statsMatch  = gradeGE(grades.str, cond.minStr)
                         and gradeGE(grades.spd, cond.minSpd)
                         and gradeGE(grades.spc, cond.minSpc)

        -- Skin check — independent, any skin in cond.skins stops regardless of stand
        local skinMatch = false
        if info.skin then
            for _, s in ipairs(cond.skins) do
                if info.skin:lower():find(s:lower(), 1, true) then
                    skinMatch = true
                    break
                end
            end
        end
        if skinMatch then
            return allS and "CONDITION_JACKPOT" or "CONDITION_SKIN"
        end

        -- Stand + stats + optional trait
        if standMatch and statsMatch then
            if #cond.traits > 0 then
                for _, tr in ipairs(cond.traits) do
                    if traitLower == tr:lower() then
                        return "CONDITION_TRAIT"
                    end
                end
            else
                return "CONDITION_MET"
            end
        end
    end

    return nil
end

--==========================================================
--  WEBHOOK
--==========================================================
local function sendWebhook(info, reason)
    if Settings.webhookURL == "" then return end

    local shouldSend = false
    if reason == "GLOBAL_JACKPOT" or reason == "CONDITION_JACKPOT" then
        shouldSend = Settings.webhookOnJackpot
    elseif reason == "CONDITION_MET" or reason == "CONDITION_SKIN" or reason == "CONDITION_TRAIT" then
        shouldSend = Settings.webhookOnCondition
    end
    if not shouldSend then return end

    local grades = {
        numToGrade(info.strength),
        numToGrade(info.speed),
        numToGrade(info.specialty),
    }
    local body = HttpService:JSONEncode({
        username = "StandRoll HUD",
        embeds = {{
            title = reason:gsub("_"," "),
            description = string.format(
                "**%s**%s\nTrait: %s\nSTR `%s`  SPD `%s`  SPC `%s`",
                info.name,
                info.skin and ("  ·  skin: **"..info.skin.."**") or "",
                info.trait,
                grades[1], grades[2], grades[3]
            ),
            color = 0xF0C030,
        }},
    })

    task.spawn(function()
        pcall(function()
            HttpService:PostAsync(Settings.webhookURL, body, Enum.HttpContentType.ApplicationJson)
        end)
    end)
end

--==========================================================
--  AUTOROLL ENGINE
--==========================================================
local alive          = true
local autoroll       = false
local autorollThread = 0
local stopReason     = "IDLE"
local connections    = {}

local function stopAutoroll(reason)
    autoroll   = false
    stopReason = reason or "MANUAL"
end

local function startAutoroll()
    if autoroll then return end
    autoroll = true
    stopReason = "IDLE"
    autorollThread += 1
    local myThread = autorollThread
    task.spawn(function()
        while alive and autoroll and autorollThread == myThread do
            useItem:FireServer("Stand Arrow")
            task.wait(Settings.autorollDelay)
        end
    end)
end

local function toggleAutoroll()
    if autoroll then stopAutoroll("MANUAL") else startAutoroll() end
end

--==========================================================
--  KILL
--==========================================================
local function killScript()
    if not alive then return end
    alive    = false
    autoroll = false
    autorollThread += 1
    for _, c in ipairs(connections) do pcall(function() c:Disconnect() end) end
    table.clear(connections)
    local hud = PlayerGui:FindFirstChild("StandRollHUD")
    if hud then hud:Destroy() end
    script:Destroy()
end

