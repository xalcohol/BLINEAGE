--========================
-- Runtime + Connections
--========================
local alive = true
local connections = {}

local autoroll = false
local autorollThreadId = 0

local rainbowTargets = {
	skin = false,
	strength = false,
	speed = false,
	specialty = false,
}

local specialStandActive = false
local legendarySkinFlashyActive = false
local allSStopActive = false

local lastStandSignature = nil
local flashTweenIn = nil
local flashTweenOut = nil

local function setNormalStatVisual(label, glow)
	label.TextColor3 = Color3.fromRGB(255, 215, 120)
	glow.Color = Color3.fromRGB(255, 215, 120)
	glow.Transparency = 0.2
end

local function applyRainbowToLabel(label, glow, hue)
	local color = Color3.fromHSV(hue, 1, 1)
	label.TextColor3 = color
	if glow then
		glow.Color = color
		glow.Transparency = 0
	end
end

local function triggerLegendaryFlash()
	if flashTweenIn then pcall(function() flashTweenIn:Cancel() end) end
	if flashTweenOut then pcall(function() flashTweenOut:Cancel() end) end

	flashOverlay.BackgroundTransparency = 0.82
	flashTweenIn = TweenService:Create(
		flashOverlay,
		TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ BackgroundTransparency = 0.55 }
	)

	flashTweenOut = TweenService:Create(
		flashOverlay,
		TweenInfo.new(0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ BackgroundTransparency = 1 }
	)

	flashTweenIn:Play()
	flashTweenIn.Completed:Once(function()
		if flashTweenOut then flashTweenOut:Play() end
	end)
end

local function setNormalNameVisual()
	nameLabel.TextColor3 = Color3.fromRGB(240, 240, 245)
	nameStroke.Color = Color3.fromRGB(255, 255, 255)
	nameStroke.Transparency = 0.35
end

local function setNormalPanelVisual()
	stroke.Color = Color3.fromRGB(80, 80, 95)
	stroke.Thickness = 2
	accentBar.BackgroundColor3 = Color3.fromRGB(120, 20, 20)
end

local function stopAutoroll()
	autoroll = false
end

-- Stop autoroll if:
-- A) special stand AND has skin
-- B) special stand AND all three stats are S
local function checkAndStopAutorollIfNeeded(isSpecial, hasSkin, allS)
	if autoroll and ( (isSpecial and hasSkin) or (isSpecial and allS) ) then
		stopAutoroll()
	end
end

local function updateHUD()
	if not alive then return end

	local raw = tostring(StandValueObj.Value)
	local info = parseStandValue(raw)

	nameLabel.Text = info.name

	local hasSkin = info.skin ~= nil and info.skin ~= ""
	local isSpecial = SPECIAL_STANDS[info.name] == true

	if hasSkin then
		skinLabel.Visible = true
		skinLabel.Text = "Skin: " .. info.skin
		traitLabel.Position = UDim2.new(0, 12, 0, 66)
		rainbowTargets.skin = true
	else
		skinLabel.Visible = false
		skinLabel.TextColor3 = Color3.fromRGB(200, 200, 210)
		skinStroke.Color = Color3.fromRGB(255, 255, 255)
		skinStroke.Transparency = 0.25
		traitLabel.Position = UDim2.new(0, 12, 0, 44)
		rainbowTargets.skin = false
	end

	traitLabel.Text = ('Trait: "%s"'):format(info.trait)

	local strengthRank = numToLetter(info.strength)
	local speedRank = numToLetter(info.speed)
	local specialtyRank = numToLetter(info.specialty)

	strengthText.Text = ("%s  (%d)"):format(strengthRank, info.strength)
	speedText.Text = ("%s  (%d)"):format(speedRank, info.speed)
	specialtyText.Text = ("%s  (%d)"):format(specialtyRank, info.specialty)

	rainbowTargets.strength = (strengthRank == "S")
	rainbowTargets.speed = (speedRank == "S")
	rainbowTargets.specialty = (specialtyRank == "S")

	if not rainbowTargets.strength then setNormalStatVisual(strengthText, strengthGlow) end
	if not rainbowTargets.speed then setNormalStatVisual(speedText, speedGlow) end
	if not rainbowTargets.specialty then setNormalStatVisual(specialtyText, specialtyGlow) end

	specialStandActive = isSpecial
	legendarySkinFlashyActive = isSpecial and hasSkin
	allSStopActive = isSpecial and (strengthRank == "S" and speedRank == "S" and specialtyRank == "S")

	if not specialStandActive then
		setNormalNameVisual()
	end
	if not legendarySkinFlashyActive then
		setNormalPanelVisual()
	end

	-- Stop autoroll on either condition
	checkAndStopAutorollIfNeeded(isSpecial, hasSkin, allSStopActive)

	-- Flash only when special+skin AND the roll actually changes (avoid flashing every frame)
	local signature = string.format("%s|%s|%s|%s|%s|%s",
		tostring(info.name),
		tostring(info.skin),
		tostring(info.trait),
		tostring(info.strength),
		tostring(info.speed),
		tostring(info.specialty)
	)

	if signature ~= lastStandSignature then
		lastStandSignature = signature

		if legendarySkinFlashyActive then
			triggerLegendaryFlash()
		end
	end
end

local function doRoll()
	useItem:FireServer(ITEM_NAME)
	task.delay(0.15, updateHUD)
	task.delay(0.35, updateHUD)
end

local function startAutoroll()
	if autoroll then return end
	autoroll = true

	autorollThreadId += 1
	local myId = autorollThreadId

	task.spawn(function()
		while alive and autoroll and autorollThreadId == myId do
			doRoll()
			task.wait(AUTOROLL_DELAY)
		end
	end)
end

local function toggleAutoroll()
	if autoroll then
		stopAutoroll()
	else
		startAutoroll()
	end
end

local function killScript()
	if not alive then return end
	alive = false
	autoroll = false
	autorollThreadId += 1

	for _, c in ipairs(connections) do
		pcall(function() c:Disconnect() end)
	end
	table.clear(connections)

	if gui and gui.Parent then
		gui:Destroy()
	end

	script:Destroy()
end

-- Initial update + listeners
updateHUD()
table.insert(connections, StandValueObj.Changed:Connect(updateHUD))

table.insert(connections, RunService.RenderStepped:Connect(function()
	if not alive then return end

	local rainbowHue = (tick() * 0.8) % 1

	if rainbowTargets.skin and skinLabel.Visible then
		applyRainbowToLabel(skinLabel, skinStroke, rainbowHue)
	end

	if rainbowTargets.strength then
		applyRainbowToLabel(strengthText, strengthGlow, rainbowHue)
	end

	if rainbowTargets.speed then
		applyRainbowToLabel(speedText, speedGlow, rainbowHue)
	end

	if rainbowTargets.specialty then
		applyRainbowToLabel(specialtyText, specialtyGlow, rainbowHue)
	end

	-- Special stand name red strobe
	if specialStandActive then
		local pulse = (math.sin(tick() * 6) + 1) / 2
		local darkRed = Color3.fromRGB(110, 0, 0)
		local brightRed = Color3.fromRGB(255, 60, 60)
		local strokeRed = Color3.fromRGB(255, 130, 130)

		local textColor = lerpColor(darkRed, brightRed, pulse)
		local outlineColor = lerpColor(Color3.fromRGB(120, 0, 0), strokeRed, pulse)

		nameLabel.TextColor3 = textColor
		nameStroke.Color = outlineColor
		nameStroke.Transparency = 0.1
	end

	-- Flashy border/panel strobe ONLY when special + skin
	if legendarySkinFlashyActive then
		local pulse = (math.sin(tick() * 8) + 1) / 2
		local panelColor = lerpColor(Color3.fromRGB(100, 0, 0), Color3.fromRGB(255, 70, 70), pulse)
		local accentColor = lerpColor(Color3.fromRGB(140, 0, 0), Color3.fromRGB(255, 120, 120), pulse)

		stroke.Color = panelColor
		stroke.Thickness = 2 + pulse * 2
		accentBar.BackgroundColor3 = accentColor
	end
end))

--========================
-- Keybinds
--========================
table.insert(connections, UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if not alive then return end
	if gameProcessed then return end

	if input.KeyCode == KILL_KEY then
		killScript()
		return
	end

	if input.KeyCode == AUTOROLL_KEY then
		toggleAutoroll()
		return
	end

	if input.KeyCode == KEYBIND then
		if autoroll then
			stopAutoroll()
			return
		end

		doRoll()
		return
	end
end))
