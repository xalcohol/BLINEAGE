--========================
-- Runtime state
--========================
local alive           = true
local connections     = {}
local autoroll        = false
local autorollThreadId = 0
local stopReason      = "IDLE"

local rainbowTargets = { strength=false, speed=false, specialty=false, skin=false }
local specialStandActive   = false
local legendaryFlashActive = false
local lastStandSignature   = nil
local flashTweenIn, flashTweenOut = nil, nil

--========================
-- Visual helpers
--========================

-- Dark-tinted chip backgrounds (letter stays white over these)
local CHIP_BG = {
	S = Color3.fromRGB(58,  42,  6),
	A = Color3.fromRGB(12,  36,  68),
	B = Color3.fromRGB(12,  50,  20),
	C = Color3.fromRGB(36,  36,  46),
	D = Color3.fromRGB(24,  24,  32),
}
-- Chip border colors per grade (vivid, since letter stays white)
local CHIP_BORDER_STATIC = {
	S = Color3.fromRGB(255, 200, 60),
	A = Color3.fromRGB(100, 170, 255),
	B = Color3.fromRGB(80,  210, 100),
	C = Color3.fromRGB(90,  90,  108),
	D = Color3.fromRGB(50,  50,  62),
}

local function setChipGrade(key, letter)
	local obj = statObjects[key]
	if not obj then return end
	obj.gradeLabel.Text       = letter ~= "" and letter or "—"
	obj.chip.BackgroundColor3 = CHIP_BG[letter]           or Color3.fromRGB(28,28,36)
	obj.chipStroke.Color      = CHIP_BORDER_STATIC[letter] or Color3.fromRGB(50,50,62)
end

local function triggerFlash()
	if flashTweenIn  then pcall(function() flashTweenIn:Cancel()  end) end
	if flashTweenOut then pcall(function() flashTweenOut:Cancel() end) end

	flashOverlay.BackgroundTransparency = 0.80
	flashTweenIn = TweenService:Create(flashOverlay,
		TweenInfo.new(0.07, Enum.EasingStyle.Quad), { BackgroundTransparency = 0.50 })
	flashTweenOut = TweenService:Create(flashOverlay,
		TweenInfo.new(0.50, Enum.EasingStyle.Quad), { BackgroundTransparency = 1 })
	flashTweenIn:Play()
	flashTweenIn.Completed:Once(function()
		if flashTweenOut then flashTweenOut:Play() end
	end)
end

--========================
-- Autoroll controls
--========================
local function stopAutoroll(reason)
	autoroll   = false
	stopReason = reason or "MANUAL"
end

local function startAutoroll()
	if autoroll then return end
	autoroll   = true
	stopReason = "IDLE"
	autorollThreadId += 1
	local myId = autorollThreadId
	task.spawn(function()
		while alive and autoroll and autorollThreadId == myId do
			useItem:FireServer(ITEM_NAME)
			task.wait(AUTOROLL_DELAY)
		end
	end)
end

local function toggleAutoroll()
	if autoroll then stopAutoroll("MANUAL") else startAutoroll() end
end

--========================
-- HUD update
--========================
local function updateHUD()
	if not alive then return end

	local info = parseStandValue(StandValueObj.Value)

	nameLabel.Text = info.name

	-- Skin pill
	if info.skin and info.skin ~= "" then
		skinPillLabel.Text  = info.skin
		local tw = game:GetService("TextService"):GetTextSize(
			info.skin, 12, Enum.Font.GothamBold, Vector2.new(300,22)).X
		skinPill.Size       = UDim2.new(0, tw + 20, 0, 22)
		skinPill.Visible    = true
		rainbowTargets.skin = true
	else
		skinPill.Visible    = false
		rainbowTargets.skin = false
	end

	traitLabel.Text = info.trait ~= "Unknown" and info.trait or "—"

	local grades = {
		strength  = numToLetter(info.strength),
		speed     = numToLetter(info.speed),
		specialty = numToLetter(info.specialty),
	}

	for key, letter in pairs(grades) do
		rainbowTargets[key] = (letter == "S")
		setChipGrade(key, letter)   -- sets bg + border; letter is always white
	end

	specialStandActive   = SPECIAL_STANDS[info.name] == true
	legendaryFlashActive = specialStandActive and (info.skin ~= nil and info.skin ~= "")

	local sig = ("%s|%s|%s|%d|%d|%d"):format(
		info.name, tostring(info.skin), info.trait,
		info.strength, info.speed, info.specialty)

	if sig ~= lastStandSignature then
		lastStandSignature = sig

		if legendaryFlashActive then triggerFlash() end

		local skin        = info.skin or ""
		local standName   = info.name
		local allS        = grades.strength == "S" and grades.speed == "S" and grades.specialty == "S"
		local isTranscendent = info.trait:lower() == "transcendent"

		-- Check if current skin is in the target skin list
		-- Galaxy Garou stops regardless of stand; all others require their specific stand
		local isTargetSkin = false
		if GALAXY_SKINS[skin] then
			isTargetSkin = true
		elseif TARGET_SKINS[standName] then
			for _, s in ipairs(TARGET_SKINS[standName]) do
				if skin:lower():find(s:lower(), 1, true) then
					isTargetSkin = true
					break
				end
			end
		end

		-- Stop conditions (all require special stand EXCEPT isTargetSkin which has its own rule)
		if autoroll then
			if isTargetSkin then
				-- Jackpot if target skin AND all S
				if allS then
					stopAutoroll("JACKPOT")
				else
					stopAutoroll("TARGET_SKIN")
				end
			elseif specialStandActive then
				if isTranscendent then
					stopAutoroll("TRANSCENDENT")
				elseif STOP_ON_ALL_S and allS then
					stopAutoroll("ALL_S")
				end
			end
		end
	end
end

local function doRoll()
	useItem:FireServer(ITEM_NAME)
	task.delay(0.3, updateHUD)
end

--========================
-- Kill
--========================
local function killScript()
	if not alive then return end
	alive = false
	autoroll = false
	autorollThreadId += 1
	for _, c in ipairs(connections) do pcall(function() c:Disconnect() end) end
	table.clear(connections)
	if gui and gui.Parent then gui:Destroy() end
	script:Destroy()
end

