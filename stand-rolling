-- Keybinds
--========================
table.insert(connections, UserInputService.InputBegan:Connect(function(inp, gp)
	if not alive or gp then return end

	if inp.KeyCode == KILL_KEY then
		killScript()
	elseif inp.KeyCode == AUTOROLL_KEY then
		toggleAutoroll()
	elseif inp.KeyCode == KEYBIND then
		if autoroll then stopAutoroll("MANUAL")
		else doRoll() end
	end
end))
