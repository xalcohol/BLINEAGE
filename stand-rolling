--========================
-- Runtime + Connections
--========================
local alive = true
local connections = {}

local autoroll = false
local autorollThreadId = 0

local function updateHUD()
	if not alive then return end
	local info = parseStandValue(StandValueObj.Value)

	nameLabel.Text = info.name

	if info.skin and info.skin ~= "" then
		skinLabel.Visible = true
		skinLabel.Text = "Skin: " .. info.skin
		traitLabel.Position = UDim2.new(0, 12, 0, 66)
	else
		skinLabel.Visible = false
		traitLabel.Position = UDim2.new(0, 12, 0, 44)
	end

	traitLabel.Text = ('Trait: "%s"'):format(info.trait)

	strengthText.Text = ("%s  (%d)"):format(numToLetter(info.strength), info.strength)
	speedText.Text = ("%s  (%d)"):format(numToLetter(info.speed), info.speed)
	specialtyText.Text = ("%s  (%d)"):format(numToLetter(info.specialty), info.specialty)
end

local function doRoll()
	useItem:FireServer(ITEM_NAME)
	task.delay(0.15, updateHUD)
	task.delay(0.35, updateHUD)
end

local function stopAutoroll()
	autoroll = false
end

local function startAutoroll()
	if autoroll then return end
	autoroll = true

	autorollThreadId += 1
	local myId = autorollThreadId

	task.spawn(function()
		while alive and autoroll and autorollThreadId == myId do
			doRoll()
			task.wait(AUTOROLL_DELAY)
		end
	end)
end

local function toggleAutoroll()
	if autoroll then
		stopAutoroll()
	else
		startAutoroll()
	end
end

local function killScript()
	if not alive then return end
	alive = false
	autoroll = false
	autorollThreadId += 1

	for _, c in ipairs(connections) do
		pcall(function() c:Disconnect() end)
	end
	table.clear(connections)

	if gui and gui.Parent then
		gui:Destroy()
	end

	script:Destroy()
end

-- Initial update + listen for stand changes
updateHUD()
table.insert(connections, StandValueObj.Changed:Connect(updateHUD))

--========================
-- Keybinds
--========================
table.insert(connections, UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if not alive then return end
	if gameProcessed then return end

	-- Kill
	if input.KeyCode == KILL_KEY then
		killScript()
		return
	end

	-- Autoroll toggle (')
	if input.KeyCode == AUTOROLL_KEY then
		toggleAutoroll()
		return
	end

	-- Manual / Panic stop (T)
	if input.KeyCode == KEYBIND then
		if autoroll then
			-- Panic stop ONLY (no extra roll)
			stopAutoroll()
			return
		end

		-- Normal manual roll
		doRoll()
		return
	end
end))
