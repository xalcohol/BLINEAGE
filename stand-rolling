--========================
-- RenderStepped
--========================
table.insert(connections, RunService.RenderStepped:Connect(function()
	if not alive then return end

	local t = tick()
	-- Slow aurora hue cycle (0.12 = ~8 second full cycle — smooth, not stroby)
	local hue = (t * 0.12) % 1

	-- S-grade chips: slow rainbow border only, chip bg and white letter unchanged
	for _, key in ipairs({"strength","speed","specialty"}) do
		if rainbowTargets[key] then
			statObjects[key].chipStroke.Color = Color3.fromHSV(hue, 0.88, 1)
			statObjects[key].chip.BackgroundColor3 = Color3.fromRGB(58, 42, 6)
		end
	end

	-- Any S stat? Card border also does a slow rainbow cycle
	local anyS = rainbowTargets.strength or rainbowTargets.speed or rainbowTargets.specialty
	if anyS and not legendaryFlashActive then
		cardStroke.Color     = Color3.fromHSV(hue, 0.7, 0.95)
		cardStroke.Thickness = 2
	end

	-- Skin pill rainbow (slow, matches chip hue)
	if rainbowTargets.skin and skinPill.Visible then
		skinPill.BackgroundColor3 = Color3.fromHSV(hue, 0.88, 1)
		skinPillLabel.TextColor3  = Color3.fromRGB(10, 10, 10)
	elseif not rainbowTargets.skin then
		skinPill.BackgroundColor3 = Color3.fromRGB(255, 200, 60)
		skinPillLabel.TextColor3  = Color3.fromRGB(20, 14, 4)
	end

	-- Special stand name pulse
	if specialStandActive then
		local p = (math.sin(t * 5.5) + 1) * 0.5
		nameLabel.TextColor3 = lerpColor(Color3.fromRGB(255,60,60), Color3.fromRGB(255,160,160), p)
	else
		nameLabel.TextColor3 = Color3.fromRGB(245, 245, 250)
	end

	-- Legendary card border (special + skin) — red pulse overrides rainbow
	if legendaryFlashActive then
		local p = (math.sin(t * 7) + 1) * 0.5
		cardStroke.Color     = lerpColor(Color3.fromRGB(180,20,20), Color3.fromRGB(255,80,80), p)
		cardStroke.Thickness = 1.5 + p * 2
	elseif not anyS then
		cardStroke.Color     = Color3.fromRGB(50, 50, 60)
		cardStroke.Thickness = 1.5
	end

	-- Autoroll button
	if autoroll then
		local p = (math.sin(t * 4) + 1) * 0.5
		autoBtn.BackgroundColor3 = lerpColor(Color3.fromRGB(140,20,20), Color3.fromRGB(200,40,40), p)
		autoBtnStroke.Color      = lerpColor(Color3.fromRGB(200,50,50), Color3.fromRGB(255,100,100), p)
		autoBtn.TextColor3       = Color3.fromRGB(255, 230, 230)
		autoBtn.Text             = "AUTO  ON"
		statusLabel.Text         = "rolling..."
		statusLabel.TextColor3   = Color3.fromRGB(200, 80, 80)
	else
		autoBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 38)
		autoBtnStroke.Color      = Color3.fromRGB(55, 55, 68)
		autoBtn.TextColor3       = Color3.fromRGB(160, 160, 175)
		autoBtn.Text             = "AUTO  OFF"

		if stopReason == "JACKPOT" then
			statusLabel.Text       = "✦  jackpot!"
			statusLabel.TextColor3 = Color3.fromRGB(255, 200, 60)
		elseif stopReason == "TRANSCENDENT" then
			statusLabel.Text       = "★  transcendent"
			statusLabel.TextColor3 = Color3.fromRGB(180, 120, 255)
		elseif stopReason == "ALL_S" then
			statusLabel.Text       = "◆  all S"
			statusLabel.TextColor3 = Color3.fromRGB(255, 200, 60)
		elseif stopReason == "TARGET_SKIN" then
			statusLabel.Text       = "◈  rare skin"
			statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
		elseif stopReason == "MANUAL" then
			statusLabel.Text       = "stopped"
			statusLabel.TextColor3 = Color3.fromRGB(80, 80, 95)
		else
			statusLabel.Text       = "IDLE"
			statusLabel.TextColor3 = Color3.fromRGB(60, 60, 75)
		end
	end
end))

