--========================
-- Helpers
--========================
local function clamp(n, a, b)
	n = tonumber(n) or a
	if n < a then return a end
	if n > b then return b end
	return n
end

local function numToLetter(n)
	-- 1=D, 2=C, 3=B, 4=A, 5=S
	n = clamp(n, 1, 5)
	local map = { "D", "C", "B", "A", "S" }
	return map[n]
end

local function extractFirstJsonObject(s)
	s = tostring(s or "")
	local depth = 0
	local startIndex

	for i = 1, #s do
		local c = s:sub(i, i)
		if c == "{" then
			if depth == 0 then startIndex = i end
			depth += 1
		elseif c == "}" then
			if depth > 0 then
				depth -= 1
				if depth == 0 and startIndex then
					return s:sub(startIndex, i)
				end
			end
		end
	end
	return nil
end

local function parseStandValue(raw)
	raw = tostring(raw or "")

	local info = {
		name = "Unknown",
		skin = nil,
		trait = "Unknown",
		strength = 1,
		speed = 1,
		specialty = 1,
	}

	local ok, decoded = pcall(function()
		return HttpService:JSONDecode(raw)
	end)

	if not ok or type(decoded) ~= "table" then
		local extracted = extractFirstJsonObject(raw)
		if extracted then
			local ok2, decoded2 = pcall(function()
				return HttpService:JSONDecode(extracted)
			end)
			if ok2 and type(decoded2) == "table" then
				ok, decoded = true, decoded2
			end
		end
	end

	if ok and type(decoded) == "table" then
		if type(decoded.Name) == "string" and decoded.Name ~= "" then
			info.name = decoded.Name
		end
		if type(decoded.Skin) == "string" and decoded.Skin ~= "" then
			info.skin = decoded.Skin
		end
		if type(decoded.Trait) == "string" and decoded.Trait ~= "" then
			info.trait = decoded.Trait
		end

		info.strength = clamp(decoded.Strength, 1, 5)
		info.speed = clamp(decoded.Speed, 1, 5)
		info.specialty = clamp(decoded.Specialty, 1, 5)
	end

	return info
end

local function makeDraggable(frame)
	frame.Active = true

	local dragging = false
	local dragStart, startPos
	local dragInput

	local function update(input)
		local delta = input.Position - dragStart
		frame.Position = UDim2.new(
			startPos.X.Scale, startPos.X.Offset + delta.X,
			startPos.Y.Scale, startPos.Y.Offset + delta.Y
		)
	end

	frame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = frame.Position

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	frame.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement
			or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			update(input)
		end
	end)
end

