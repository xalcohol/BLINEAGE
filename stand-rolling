--========================
-- Helpers
--========================
local function clamp(n, a, b)
	n = tonumber(n) or a
	return math.max(a, math.min(b, n))
end

local function numToLetter(n)
	return ({"D","C","B","A","S"})[clamp(n,1,5)]
end

local function extractFirstJsonObject(s)
	s = tostring(s or "")
	local depth, startIndex = 0, nil
	for i = 1, #s do
		local c = s:sub(i,i)
		if c == "{" then
			if depth == 0 then startIndex = i end
			depth += 1
		elseif c == "}" and depth > 0 then
			depth -= 1
			if depth == 0 and startIndex then
				return s:sub(startIndex, i)
			end
		end
	end
end

local function parseStandValue(raw)
	raw = tostring(raw or "")
	local info = { name="Unknown", skin=nil, trait="Unknown", strength=1, speed=1, specialty=1 }

	local ok, decoded = pcall(HttpService.JSONDecode, HttpService, raw)
	if not ok or type(decoded) ~= "table" then
		local ex = extractFirstJsonObject(raw)
		if ex then
			ok, decoded = pcall(HttpService.JSONDecode, HttpService, ex)
		end
	end

	if ok and type(decoded) == "table" then
		if type(decoded.Name)  == "string" and decoded.Name  ~= "" then info.name  = decoded.Name  end
		if type(decoded.Skin)  == "string" and decoded.Skin  ~= "" then info.skin  = decoded.Skin  end
		if type(decoded.Trait) == "string" and decoded.Trait ~= "" then info.trait = decoded.Trait end
		info.strength  = clamp(decoded.Strength,  1, 5)
		info.speed     = clamp(decoded.Speed,     1, 5)
		info.specialty = clamp(decoded.Specialty, 1, 5)
	end
	return info
end

local function lerpColor(a, b, t)
	return Color3.new(a.R+(b.R-a.R)*t, a.G+(b.G-a.G)*t, a.B+(b.B-a.B)*t)
end

local function makeDraggable(frame)
	frame.Active = true
	local dragging, dragStart, startPos, dragInput = false
	frame.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1
		or inp.UserInputType == Enum.UserInputType.Touch then
			dragging  = true
			dragStart = inp.Position
			startPos  = frame.Position
			inp.Changed:Connect(function()
				if inp.UserInputState == Enum.UserInputState.End then dragging = false end
			end)
		end
	end)
	frame.InputChanged:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseMovement
		or inp.UserInputType == Enum.UserInputType.Touch then
			dragInput = inp
		end
	end)
	UserInputService.InputChanged:Connect(function(inp)
		if inp == dragInput and dragging then
			local d = inp.Position - dragStart
			frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset+d.X, startPos.Y.Scale, startPos.Y.Offset+d.Y)
		end
	end)
end

